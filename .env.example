# Database Configuration (Required for Prisma)
DATABASE_URL="postgresql://username:password@localhost:5432/blockmec_db"
DIRECT_URL="postgresql://username:password@localhost:5432/blockmec_db"

# Application Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Supabase
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Blockchain Configuration
NEXT_PUBLIC_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
PRIVATE_KEY=0x1234567890123456789012345678901234567890123456789012345678901234
BLOCKMEC_CONTRACT_ADDRESS=0x1234567890123456789012345678901234567890

# Payment Configuration
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-XXXXXXXXXXXXX
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-XXXXXXXXXXXXX
NEXT_PUBLIC_BLC_CRYPTO_WALLET_ADDRESS=BLM7F5EB5bB5cF88cfcEe9613368636f458800e62CB

# Security Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
SESSION_SECRET=your-session-secret-change-this-in-production
ENCRYPTION_KEY=your-32-character-encryption-key

# Development Settings
MOCK_BLOCKCHAIN=true
DEBUG=true

# Optional: Redis
# REDIS_URL=redis://localhost:6379
# UPSTASH_REDIS_REST_URL=https://<your-upstash-db>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=<your-upstash-rest-token>
# Optional: Email Configuration
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Optional: AWS S3
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_S3_BUCKET=blockmec-files

# Optional: Analytics
# NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX
# SENTRY_DSN=https://your-sentry-dsn-here
